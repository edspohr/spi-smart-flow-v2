# ─────────────────────────────────────────────────────────────
# SPI Smart Flow — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Firebase (required) ──────────────────────────────────────
# Find these in Firebase Console → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=spi-smart-flow.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Test / Mock mode ─────────────────────────────────────────
# Set to true to show the test mode banner and disable Pipefy
# integration. Does NOT affect Gemini document validation.
VITE_MOCK_MODE=false

# ── Sentry (optional) ────────────────────────────────────────
# Create a project at sentry.io and paste the DSN here.
# Leave blank to disable error tracking (safe for local dev).
VITE_SENTRY_DSN=

# ─────────────────────────────────────────────────────────────
# Cloud Functions environment (set via Firebase CLI, not here)
# ─────────────────────────────────────────────────────────────
# GEMINI_API_KEY          → firebase functions:secrets:set GEMINI_API_KEY
# PIPEFY_WEBHOOK_SECRET   → firebase functions:secrets:set PIPEFY_WEBHOOK_SECRET
# SENTRY_DSN              → set as an environment variable in Cloud Functions
#                           console or via firebase functions:config:set sentry.dsn="..."
