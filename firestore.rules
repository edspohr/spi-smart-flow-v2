rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'spi-admin';
    }

    function myCompanyId() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId
        : '';
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Admin: full access.
    // Client: read own profile + profiles sharing their companyId.
    // Client: update/create own profile only (covers magic-link auto-heal).
    match /users/{userId} {
      allow read, write: if isAdmin();

      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        (
          exists(/databases/$(database)/documents/users/$(userId)) &&
          get(/databases/$(database)/documents/users/$(userId)).data.companyId == myCompanyId()
        )
      );

      allow create: if isAuthenticated() && request.auth.uid == userId;

      allow update: if isAuthenticated() && request.auth.uid == userId;
    }

    // ── Companies ─────────────────────────────────────────────────────────────
    // Admin: full access.
    // Client: read only their own company document.
    match /companies/{companyId} {
      allow read, write: if isAdmin();
      allow read: if isAuthenticated() && myCompanyId() == companyId;
    }

    // ── OTs (Órdenes de Trabajo) ───────────────────────────────────────────────
    // Admin: full access.
    // Client: read-only, restricted to their companyId.
    match /ots/{otId} {
      allow read, write: if isAdmin();
      allow read: if isAuthenticated() && resource.data.companyId == myCompanyId();
    }

    // ── Documents ─────────────────────────────────────────────────────────────
    // Admin: full access.
    // Client: read + create for their company.
    // Client: update allowed, but cannot elevate status to 'validated' (admin-only action).
    match /documents/{docId} {
      allow read, write: if isAdmin();

      allow read: if isAuthenticated() && resource.data.companyId == myCompanyId();

      allow create: if isAuthenticated()
        && request.resource.data.companyId == myCompanyId()
        && request.resource.data.status != 'validated';

      allow update: if isAuthenticated()
        && resource.data.companyId == myCompanyId()
        && !(request.resource.data.status == 'validated' && resource.data.status != 'validated')
        && !(request.resource.data.status == 'approved' && resource.data.status != 'approved');
    }

    // ── Logs ──────────────────────────────────────────────────────────────────
    // Admin: full access.
    // Client: read + create (needed for audit trail on uploads/stage changes).
    // No client updates or deletes.
    match /logs/{logId} {
      allow read, write: if isAdmin();
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (
        resource.data.otId == 'system' ||
        isAdmin() ||
        (
          exists(/databases/$(database)/documents/ots/$(resource.data.otId)) &&
          get(/databases/$(database)/documents/ots/$(resource.data.otId)).data.companyId == myCompanyId()
        )
      );
    }

    // ── ProcedureTypes ────────────────────────────────────────────────────────
    // Admin: full access (create, edit, delete procedure type definitions).
    // Authenticated users: read-only (clients need to see requirements for their OTs).
    match /procedureTypes/{typeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── ExchangeRates ─────────────────────────────────────────────────────────
    // Admin: full access (manual overrides + restore from API).
    // Authenticated users: read-only (USD-equivalent conversions in dashboards).
    match /exchangeRates/{currency} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Signature Events (Ley 527 ledger) ────────────────────────────────────
    // Immutable audit trail of reinforced electronic signatures.
    // Append-only via the registerSignatureEvent Cloud Function (admin SDK bypasses
    // these rules). Clients can read their own signature events or those of their
    // company. No create/update/delete from client SDK ever.
    match /signatureEvents/{eventId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        resource.data.companyId == myCompanyId()
      );
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ── Rate Limits (server-managed) ─────────────────────────────────────────
    // Per-user counters for analyzeDocument (and future CFs). Written by the
    // Cloud Function via admin SDK. Admin can read for debugging; no client writes.
    match /rateLimits/{uid} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Default: deny everything else ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}