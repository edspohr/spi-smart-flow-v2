rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'spi-admin';
    }

    function myCompanyId() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId
        : '';
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Admin: full access.
    // Client: read own profile + profiles sharing their companyId.
    // Client: update/create own profile only (covers magic-link auto-heal).
    match /users/{userId} {
      allow read, write: if isAdmin();

      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        (
          exists(/databases/$(database)/documents/users/$(userId)) &&
          get(/databases/$(database)/documents/users/$(userId)).data.companyId == myCompanyId()
        )
      );

      allow create: if isAuthenticated() && request.auth.uid == userId;

      allow update: if isAuthenticated() && request.auth.uid == userId;
    }

    // ── Companies ─────────────────────────────────────────────────────────────
    // Admin: full access.
    // Client: read only their own company document.
    match /companies/{companyId} {
      allow read, write: if isAdmin();
      allow read: if isAuthenticated() && myCompanyId() == companyId;
    }

    // ── OTs (Órdenes de Trabajo) ───────────────────────────────────────────────
    // Admin: full access.
    // Client: read-only, restricted to their companyId.
    match /ots/{otId} {
      allow read, write: if isAdmin();
      allow read: if isAuthenticated() && resource.data.companyId == myCompanyId();
    }

    // ── Documents ─────────────────────────────────────────────────────────────
    // Admin: full access.
    // Client: read + create for their company.
    // Client: update allowed, but cannot elevate status to 'validated' (admin-only action).
    match /documents/{docId} {
      allow read, write: if isAdmin();

      allow read: if isAuthenticated() && resource.data.companyId == myCompanyId();

      allow create: if isAuthenticated()
        && request.resource.data.companyId == myCompanyId()
        && request.resource.data.status != 'validated';

      allow update: if isAuthenticated()
        && resource.data.companyId == myCompanyId()
        && !(request.resource.data.status == 'validated' && resource.data.status != 'validated');
    }

    // ── Logs ──────────────────────────────────────────────────────────────────
    // Admin: full access.
    // Client: read + create (needed for audit trail on uploads/stage changes).
    // No client updates or deletes.
    match /logs/{logId} {
      allow read, write: if isAdmin();
      allow read, create: if isAuthenticated();
    }

    // ── Default: deny everything else ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}