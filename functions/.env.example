# ─────────────────────────────────────────────────────────────
# SPI Smart Flow — Cloud Functions Environment Variables
# Copy this file to .env and .env.local and fill in your values.
# NEVER commit .env or .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Pipefy integration ────────────────────────────────────────
# Set to true to disable the Pipefy webhook handler entirely.
# All incoming Pipefy requests will return 200 { status: 'ignored' }.
# Useful for local testing and staging environments.
# Set to false (or omit) in production to enable the integration.
PIPEFY_DISABLED=false

# ── User activation email (activateUser function) ─────────────────────────────
# Configure your SMTP provider to send activation emails.
# Leave blank to skip email sending (function will still activate the account).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM="SPI Smart Flow <noreply@example.com>"

# ── Application URL (used in email links) ────────────────────────────────────
APP_URL=https://spi-smart-flow.web.app
